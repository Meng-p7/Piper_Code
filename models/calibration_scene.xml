<mujoco model="calibration_scene">
  <include file="agilex_piper/piper.xml"/>

  <statistic center="0 0 0.1" extent="0.4"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0 0 0 0"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <texture type="2d" name="charuco_tex" file="textures/charuco_9x14.png" width="900" height="1400"/>
    <material name="charuco_mat" texture="charuco_tex" texuniform="false" texrepeat="1 1" reflectance="0.1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" type="plane" size="1 1 0.1" material="groundplane"/>
    <body name="calibration_board" pos="0.25 0 0.1">
      <geom type="box" size="0.09 0.14 0.001" material="charuco_mat" mass="0.2"/>
    </body>
  </worldbody>
</mujoco>
