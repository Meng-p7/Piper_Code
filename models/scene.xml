<mujoco model="piper_grasp_scene">
  <include file="piper.xml"/>
  
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>
  
  <default>
    <default class="ball">
      <geom type="sphere" size="0.015" condim="3" friction="0.5 0.05 0.01" solref="0.01 1" solimp="0.9 0.95 0.001"/>
    </default>
  </default>

  <worldbody>
    <camera name="camera" pos="0.8 0 0.8" quat="0.653 0.271 0.271 0.653" fovy="60"/>
    <camera name="top_view" pos="0 0 1.5" quat="1 0 0 0" fovy="60"/>
    <camera name="eye_in_hand" pos="0 0 0.1" quat="1 0 0 0" fovy="60" mode="trackcom"/>
    
    <body name="target_ball" pos="0.4 0.2 0.015">
      <freejoint name="ball_joint"/>
      <geom name="ball_geom" size="0.015" material="ball_red" class="ball"/>
    </body>
  </worldbody>
</mujoco>
